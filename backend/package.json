{
  "name": "trustracapitaltrade-backend",
  "version": "1.0.5",
  "description": "Backend API for Trustra Capital - Secure Crypto Trading & Investment Platform",
  "private": true,
  "type": "module", 
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'No build step required for backend'",
    "preview": "npm run start"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.1",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "nodemonConfig": {
    "ignore": [
      "node_modules",
      ".git"
    ],
    "ext": "js,json",
    "watch": [
      "server.js",
      "config",
      "routes",
      "middleware",
      "utils",
      "models"
    ]
  }
}
