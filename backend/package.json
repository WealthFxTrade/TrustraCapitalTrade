{
  "name": "trustracapitaltrade-backend",
  "version": "1.0.5",
  "description": "Backend API for Trustra Capital - Secure Crypto Trading & Investment Platform",
  "private": true,
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "seed:gery": "node scripts/seedGery.js",
    "reset:production": "node scripts/resetProductionUsers.js",
    "build": "echo 'No build step required for backend'",
    "preview": "npm run start",
    "lint": "echo 'Linting not configured yet'"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "bip32": "^5.0.1",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "express": "^4.22.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "socket.io": "^4.8.3",
    "tiny-secp256k1": "^2.2.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "nodemonConfig": {
    "ignore": [
      "node_modules",
      ".git",
      "uploads/*"
    ],
    "ext": "js,json",
    "watch": [
      "server.js",
      "config",
      "routes",
      "middleware",
      "utils",
      "models",
      "scripts"
    ]
  }
}
